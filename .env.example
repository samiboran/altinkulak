# Supabase proje ayarları (Project Settings → API sekmesinden alınır)
# Bu dosyayı .env olarak kopyala ve gerçek değerleri gir. .env asla git'e girmez.
# Not: URL, projenin KÖK adresidir — sonuna /rest/v1/ veya başka bir yol EKLEME.
#      Doğru:  https://xxxxxxxx.supabase.co
#      Yanlış: https://xxxxxxxx.supabase.co/rest/v1/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AK-078: ABD hisse fiyatları (Finnhub ücretsiz plan — finnhub.io/register). Boş bırakılırsa
# ABD hisseleri portföyde fiyatlanmaz, kullanıcı manuel fiyat girer (fabrike veri yok).
VITE_FINNHUB_API_KEY=
